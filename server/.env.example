# Copy this file to server/.env, then fill in local secrets.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_SSL=require
DATABASE_POOL_SIZE=5
CLIENT_ORIGIN=http://localhost:5173
SESSION_SECRET=replace-with-a-long-random-secret
DOCUMENT_STORAGE_DIR=./data/documents
# Folder produced by Hugging Face save_pretrained(). Relative paths are resolved from server/.
BERT_MODEL_DIR=./models/bert_term_classifier/final_model
# Number of sentence/candidate pairs scored in one forward pass. Lower this if RAM is limited.
BERT_BATCH_SIZE=16
# Optional explicit Python executable/launcher. On Windows, "python" is recommended.
PYTHON=python

# Optional for local development. Generate password hashes with `npm run auth:hash --prefix server -- 'password'`.
AUTH_USERS=
